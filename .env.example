# Database (Neon Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Cloudflare R2
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=noticias-do-ceu
R2_PUBLIC_URL=https://<account_id>.r2.cloudflarestorage.com/noticias-do-ceu

# Resend (email)
RESEND_API_KEY=re_xxxxx
FROM_EMAIL=noreply@mail.noticiasdoceu.com
OWNER_EMAIL=seu_email@exemplo.com

# Site
SITE_URL=https://noticiasdoceu.com
