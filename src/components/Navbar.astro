---
interface Props {
  showCreateMemorial?: boolean;
}

const { showCreateMemorial = true } = Astro.props;
---

<nav class="fixed w-full bg-white/90 backdrop-blur-md z-50 border-b border-gray-200 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-20 items-center">
      <a href="/" class="flex-shrink-0 flex items-center gap-2 cursor-pointer">
        <i class="fa-solid fa-cloud text-accent text-2xl"></i>
        <span class="font-serif font-bold text-2xl tracking-wider uppercase text-ink">Notícias do Céu</span>
      </a>
      <div class="hidden md:flex space-x-8 items-center">
        <a href="/#como-funciona" class="text-gray-600 hover:text-accent font-medium transition-colors">Como Funciona</a>
        <a href="/#demonstracao" class="text-gray-600 hover:text-accent font-medium transition-colors">Demonstração</a>
        <a href="/blog" class="text-gray-600 hover:text-accent font-medium transition-colors">Blog</a>
        {showCreateMemorial ? (
          <a href="/#planos" class="bg-ink text-paper px-6 py-2 rounded-full font-serif font-semibold hover:bg-accent transition-colors shadow-md">
            Criar Memorial
          </a>
        ) : (
          <a href="/gift-card" class="bg-ink text-paper px-6 py-2 rounded-full font-serif font-semibold hover:bg-accent transition-colors shadow-md">
            Presenteie um Amigo
          </a>
        )}
      </div>
    </div>
  </div>
</nav>
