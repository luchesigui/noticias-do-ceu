---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Guia de Estilo | Notícias do Céu">
  <Navbar showCreateMemorial={true} />

  <div class="relative pt-32 pb-16 bg-gradient-to-b from-paper/30 to-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="text-4xl md:text-5xl font-serif font-black tracking-tight mb-4 text-ink">Guia de Estilo</h1>
      <p class="text-lg text-gray-600 max-w-2xl mx-auto font-body">Identidade visual, paleta de cores, tipografia, ícones e componentes reutilizáveis para o projeto Notícias do Céu.</p>
      <div class="w-24 h-1 bg-accent mx-auto mt-6"></div>
    </div>
  </div>

  <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 space-y-16">

    <!-- Tipografia -->
    <section class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
      <div class="border-b border-gray-100 pb-4 mb-6">
        <h2 class="text-3xl font-serif font-bold text-ink">Tipografia</h2>
        <p class="text-gray-500 text-sm mt-1">Fontes principais, tamanhos, pesos e imports configurados no projeto.</p>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 text-ink">
        <div class="space-y-6">
          <div>
            <h3 class="text-xs font-bold text-accent uppercase tracking-widest mb-2 font-sans">Fontes do Google Fonts</h3>
            <pre class="bg-gray-900 text-gray-100 p-4 rounded-lg text-xs overflow-x-auto"><code>Playfair Display (Serif) & Lora (Body)</code></pre>
          </div>
          
          <div>
            <h3 class="text-xs font-bold text-accent uppercase tracking-widest mb-2 font-sans">Configuração de Fontes (Tailwind v4 @theme)</h3>
            <pre class="bg-gray-900 text-gray-100 p-4 rounded-lg text-xs overflow-x-auto"><code>--font-serif: "Playfair Display", serif;
--font-body: "Lora", serif;</code></pre>
          </div>
        </div>

        <div class="space-y-6">
          <div>
            <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2 font-sans">Playfair Display (Serif)</h4>
            <div class="space-y-4">
              <h1 class="text-4xl font-serif font-black">Título Principal (h1)</h1>
              <h2 class="text-3xl font-serif font-bold">Título de Seção (h2)</h2>
              <h3 class="text-2xl font-serif font-semibold">Subtítulo Grande (h3)</h3>
              <h4 class="text-xl font-serif font-medium">Título de Bloco (h4)</h4>
              <h5 class="text-lg font-serif font-normal">Título Menor (h5)</h5>
              <h6 class="text-base font-serif font-light">Subtítulo Mínimo (h6)</h6>
            </div>
          </div>
          
          <div class="pt-6 border-t border-gray-100">
            <h4 class="text-xs font-bold text-gray-400 uppercase tracking-wider mb-2 font-sans">Lora (Body & Caption)</h4>
            <div class="space-y-4">
              <p class="font-body text-base">Texto de parágrafo (body) para leitura confortável das matérias e conteúdos longos do memorial.</p>
              <p class="font-serif italic text-sm text-gray-500">Legenda de imagem ou texto de rodapé explicativo (caption).</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Paleta de Cores -->
    <section class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
      <div class="border-b border-gray-100 pb-4 mb-6">
        <h2 class="text-3xl font-serif font-bold text-ink">Paleta de Cores</h2>
        <p class="text-gray-500 text-sm mt-1">Cores customizadas que criam a atmosfera de jornal vintage, juntamente com os cinzas do Tailwind utilizados.</p>
      </div>
      
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-6 text-ink">
        <div class="flex flex-col">
          <div class="h-24 w-full rounded-xl border border-gray-200 mb-3" style="background-color: #F4EADD;"></div>
          <span class="font-bold text-sm">paper</span>
          <span class="text-xs text-gray-500 font-mono">#F4EADD</span>
          <span class="text-xs mt-1 text-gray-700">Fundo do jornal</span>
        </div>
        <div class="flex flex-col">
          <div class="h-24 w-full rounded-xl border border-gray-200 mb-3" style="background-color: #2C1E16;"></div>
          <span class="font-bold text-sm">ink</span>
          <span class="text-xs text-gray-500 font-mono">#2C1E16</span>
          <span class="text-xs mt-1 text-gray-700">Texto principal, bordas</span>
        </div>
        <div class="flex flex-col">
          <div class="h-24 w-full rounded-xl border border-gray-200 mb-3" style="background-color: #8B5A2B;"></div>
          <span class="font-bold text-sm">accent</span>
          <span class="text-xs text-gray-500 font-mono">#8B5A2B</span>
          <span class="text-xs mt-1 text-gray-700">Destaques, links, botões</span>
        </div>
        <div class="flex flex-col">
          <div class="h-24 w-full rounded-xl border border-gray-200 mb-3" style="background-color: #E6D5C3;"></div>
          <span class="font-bold text-sm">vintage</span>
          <span class="text-xs text-gray-500 font-mono">#E6D5C3</span>
          <span class="text-xs mt-1 text-gray-700">Texto secundário escuro</span>
        </div>
        <div class="flex flex-col">
          <div class="h-24 w-full rounded-xl border border-gray-200 mb-3 bg-white"></div>
          <span class="font-bold text-sm">white</span>
          <span class="text-xs text-gray-500 font-mono">#FFFFFF</span>
          <span class="text-xs mt-1 text-gray-700">Fundo e cartões claros</span>
        </div>
      </div>

      <div class="mt-10 pt-8 border-t border-gray-100 text-ink">
        <h3 class="text-xs font-bold text-accent uppercase tracking-widest mb-4 font-sans">Cores Cinzas do Tailwind CSS</h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-4">
          <div class="flex flex-col items-center text-center">
            <div class="h-12 w-12 rounded-lg bg-gray-50 border border-gray-200 mb-2"></div>
            <span class="font-semibold text-xs text-ink">gray-50</span>
            <span class="text-[10px] text-gray-400 font-mono">#F9FAFB</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <div class="h-12 w-12 rounded-lg bg-gray-100 border border-gray-200 mb-2"></div>
            <span class="font-semibold text-xs text-ink">gray-100</span>
            <span class="text-[10px] text-gray-400 font-mono">#F3F4F6</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <div class="h-12 w-12 rounded-lg bg-gray-200 border border-gray-200 mb-2"></div>
            <span class="font-semibold text-xs text-ink">gray-200</span>
            <span class="text-[10px] text-gray-400 font-mono">#E5E7EB</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <div class="h-12 w-12 rounded-lg bg-gray-500 mb-2"></div>
            <span class="font-semibold text-xs text-ink">gray-500</span>
            <span class="text-[10px] text-gray-400 font-mono">#6B7280</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <div class="h-12 w-12 rounded-lg bg-gray-600 mb-2"></div>
            <span class="font-semibold text-xs text-ink">gray-600</span>
            <span class="text-[10px] text-gray-400 font-mono">#4B5563</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <div class="h-12 w-12 rounded-lg bg-gray-700 mb-2"></div>
            <span class="font-semibold text-xs text-ink">gray-700</span>
            <span class="text-[10px] text-gray-400 font-mono">#374151</span>
          </div>
          <div class="flex flex-col items-center text-center">
            <div class="h-12 w-12 rounded-lg bg-gray-900 mb-2"></div>
            <span class="font-semibold text-xs text-ink">gray-900</span>
            <span class="text-[10px] text-gray-400 font-mono">#111827</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Ícones -->
    <section class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8">
      <div class="border-b border-gray-100 pb-4 mb-6">
        <h2 class="text-3xl font-serif font-bold text-ink">Ícones</h2>
        <p class="text-gray-500 text-sm mt-1">Ícones FontAwesome usados para navegação, identificadores, redes sociais e interface.</p>
      </div>
      
      <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-6 text-ink">
        <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-accent text-lg shadow-sm">
            <i class="fa-solid fa-cloud"></i>
          </div>
          <span class="text-xs font-mono">fa-cloud</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-accent text-lg shadow-sm">
            <i class="fa-solid fa-paw"></i>
          </div>
          <span class="text-xs font-mono">fa-paw</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-accent text-lg shadow-sm">
            <i class="fa-solid fa-camera-retro"></i>
          </div>
          <span class="text-xs font-mono">fa-camera-retro</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-accent text-lg shadow-sm">
            <i class="fa-solid fa-laptop-code"></i>
          </div>
          <span class="text-xs font-mono">fa-laptop-code</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-accent text-lg shadow-sm">
            <i class="fa-solid fa-calendar-check"></i>
          </div>
          <span class="text-xs font-mono">fa-calendar-check</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-accent text-lg shadow-sm">
            <i class="fa-solid fa-forward-step"></i>
          </div>
          <span class="text-xs font-mono">fa-forward-step</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-accent text-lg shadow-sm">
            <i class="fa-solid fa-arrow-right"></i>
          </div>
          <span class="text-xs font-mono">fa-arrow-right</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-accent text-lg shadow-sm">
            <i class="fa-solid fa-eye"></i>
          </div>
          <span class="text-xs font-mono">fa-eye</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-accent text-lg shadow-sm">
            <i class="fa-solid fa-heart"></i>
          </div>
          <span class="text-xs font-mono">fa-heart</span>
        </div>
        <div class="flex items-center gap-3 p-3 bg-gray-50 rounded-xl border border-gray-100">
          <div class="w-10 h-10 bg-white rounded-lg flex items-center justify-center text-accent text-lg shadow-sm">
            <i class="fa-solid fa-star"></i>
          </div>
          <span class="text-xs font-mono">fa-star</span>
        </div>
      </div>
    </section>

    <!-- Componentes -->
    <section class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 space-y-8 text-ink">
      <div class="border-b border-gray-100 pb-4 mb-6">
        <h2 class="text-3xl font-serif font-bold text-ink">Componentes</h2>
        <p class="text-gray-500 text-sm mt-1">Elementos interativos e estruturais reutilizáveis e consistentes com o visual da landing page.</p>
      </div>

      <div class="space-y-6">
        <h3 class="text-xs font-bold text-accent uppercase tracking-widest font-sans">Botões</h3>
        <div class="flex flex-wrap gap-4 items-center">
          <div class="space-y-2">
            <span class="text-xs text-gray-400 block font-sans">Primário (Destaque)</span>
            <a href="#" class="bg-accent text-white px-8 py-4 rounded-full font-serif font-bold text-lg hover:bg-ink transition-all shadow-lg inline-flex items-center gap-2">
              Começar Homenagem <i class="fa-solid fa-arrow-right"></i>
            </a>
          </div>
          <div class="space-y-2">
            <span class="text-xs text-gray-400 block font-sans">Secundário (Esboço)</span>
            <a href="#" class="bg-white text-ink border-2 border-ink px-8 py-4 rounded-full font-serif font-bold text-lg hover:bg-gray-50 transition-all inline-flex items-center gap-2">
              Ver Exemplo <i class="fa-regular fa-eye"></i>
            </a>
          </div>
          <div class="space-y-2">
            <span class="text-xs text-gray-400 block font-sans">Menu de Ação</span>
            <a href="#" class="bg-ink text-paper px-6 py-2 rounded-full font-serif font-semibold hover:bg-accent transition-colors shadow-md inline-block">
              Criar Memorial
            </a>
          </div>
        </div>
      </div>

      <div class="space-y-6 pt-6 border-t border-gray-100">
        <h3 class="text-xs font-bold text-accent uppercase tracking-widest font-sans">Borda Dupla (border-double-thick)</h3>
        <div class="p-6 border-double-thick bg-gray-50">
          <p class="text-center font-serif font-bold">Estilo de borda dupla no formato clássico de cabeçalho de jornais.</p>
        </div>
      </div>

      <div class="space-y-6 pt-6 border-t border-gray-100">
        <h3 class="text-xs font-bold text-accent uppercase tracking-widest font-sans">Separador com Coração (separator-line)</h3>
        <div class="bg-paper p-6 rounded-xl">
          <div class="separator-line"></div>
        </div>
      </div>

      <div class="space-y-6 pt-6 border-t border-gray-100">
        <h3 class="text-xs font-bold text-accent uppercase tracking-widest font-sans">Card de Jornal (newspaper-container)</h3>
        <div class="newspaper-container border-double-thick p-6 max-w-md">
          <h4 class="font-serif font-black text-xl uppercase mb-2">Visual Retrô de Jornal</h4>
          <p class="font-body text-sm leading-relaxed">Possui textura granulada simulando papel impresso, sombra marcante e acabamentos em tons terrosos.</p>
        </div>
      </div>

      <div class="space-y-6 pt-6 border-t border-gray-100">
        <h3 class="text-xs font-bold text-accent uppercase tracking-widest font-sans">Header do Jornal</h3>
        <div class="newspaper-container border-double-thick p-6">
          <header class="text-center">
            <div class="flex justify-between items-center border-y-newspaper py-2 mb-4">
              <div class="text-xs font-bold uppercase w-1/3 text-left">
                <i class="fa-solid fa-cloud text-accent"></i> Edição Diária
              </div>
              <div class="text-xs font-bold uppercase w-1/3 text-center tracking-widest text-accent">
                Amor Eterno
              </div>
              <div class="text-xs font-bold uppercase w-1/3 text-right">
                25 de Maio, 2026
              </div>
            </div>
            
            <h1 class="font-serif text-3xl sm:text-5xl font-black uppercase tracking-tighter mb-2 text-ink">
              Notícias do Céu
            </h1>
            <p class="font-serif text-xs italic mb-4">
              O JORNAL DAS BOAS NOTÍCIAS E DAS HISTÓRIAS QUE AQUECEM O CORAÇÃO
            </p>
            
            <div class="border-y-newspaper py-1 text-xs font-bold uppercase tracking-widest">
              DIRETAMENTE DO PARAÍSO PARA A TERRA • DISTRIBUIÇÃO EXCLUSIVA
            </div>
          </header>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</Layout>
