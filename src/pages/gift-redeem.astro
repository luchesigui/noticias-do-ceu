---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Resgatar Presente | Notícias do Céu">
  <Navbar showCreateMemorial={false} />

  <!-- Hero Section -->
  <section class="relative pt-32 pb-16 lg:pt-40 lg:pb-20 overflow-hidden bg-gradient-to-b from-paper/40 to-white">
    <!-- Background decorations -->
    <i class="fa-solid fa-cloud text-gray-200 text-9xl absolute -top-10 -left-10 opacity-30 pointer-events-none animate-cloud-slow-1"></i>
    <i class="fa-solid fa-cloud text-gray-200 text-9xl absolute -bottom-10 -right-10 opacity-30 pointer-events-none animate-cloud-slow-2"></i>

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 relative">
      <div class="text-center">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-accent/10 text-accent font-semibold text-sm mb-6 border border-accent/20">
          <i class="fa-solid fa-gift"></i> Você recebeu um presente especial
        </div>
        <h1 class="text-4xl font-serif font-black leading-tight mb-6 text-ink">
          Resgate seu<br/>
          <span class="italic text-accent">Memorial Eterno</span>
        </h1>
        <p class="text-lg text-gray-700 max-w-xl mx-auto leading-relaxed">
          Alguém preparou um espaço de carinho para você honrar a memória do seu companheiro de quatro patas.
        </p>
      </div>
    </div>
  </section>

  <!-- Main Content -->
  <section class="pb-24 bg-white">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="newspaper-container border-double-thick p-6 sm:p-10 relative">

        <!-- STEP 1: Enter Code -->
        <div id="step-1" class="step-content active">
          <div class="text-center mb-8">
            <div class="w-16 h-16 mx-auto bg-accent/10 rounded-full flex items-center justify-center mb-4">
              <i class="fa-solid fa-envelope-open-text text-accent text-2xl"></i>
            </div>
            <h2 class="text-3xl font-serif font-bold text-ink mb-2">Insira o Código do Presente</h2>
            <p class="text-gray-600 font-body">Digite o código que você recebeu no e-mail ou mensagem</p>
          </div>

          <form id="redeem-form" class="space-y-6">
            <div>
              <label for="gift-code-input" class="block text-sm font-bold text-ink mb-1">Código do Gift Card</label>
              <input type="text" id="gift-code-input" required maxlength="14"
                class="w-full px-4 py-4 rounded-lg border-2 border-ink/20 bg-white focus:border-accent focus:outline-none transition-colors font-mono text-center text-xl tracking-widest uppercase"
                placeholder="XXXX-XXXX-XXXX"
                oninput="formatCodeInput(this)">
              <p id="code-error" class="hidden text-sm text-red-600 mt-2">Código inválido. Verifique e tente novamente.</p>
            </div>

            <div>
              <label for="redeemer-name" class="block text-sm font-bold text-ink mb-1">Seu nome</label>
              <input type="text" id="redeemer-name" required
                class="w-full px-4 py-3 rounded-lg border-2 border-ink/20 bg-white focus:border-accent focus:outline-none transition-colors font-body"
                placeholder="Seu nome completo">
            </div>

            <div>
              <label for="redeemer-email" class="block text-sm font-bold text-ink mb-1">Seu e-mail</label>
              <input type="email" id="redeemer-email" required
                class="w-full px-4 py-3 rounded-lg border-2 border-ink/20 bg-white focus:border-accent focus:outline-none transition-colors font-body"
                placeholder="seu@email.com">
            </div>

            <button type="submit"
              class="w-full bg-accent text-white py-4 rounded-xl font-serif font-bold text-lg hover:bg-ink transition-colors shadow-lg flex items-center justify-center gap-2 cursor-pointer">
              <i class="fa-solid fa-gift"></i> Resgatar Presente
            </button>
          </form>
        </div>

        <!-- STEP 2: Gift Message (Preview) -->
        <div id="step-2" class="step-content">
          <div class="text-center mb-6">
            <div class="w-16 h-16 mx-auto bg-accent/10 rounded-full flex items-center justify-center mb-4">
              <i class="fa-solid fa-heart text-accent text-2xl"></i>
            </div>
            <h2 class="text-3xl font-serif font-bold text-ink mb-2">Seu Presente Especial</h2>
            <p class="text-gray-600 font-body">Alguém pensou em você com muito carinho</p>
          </div>

          <!-- Gift Card Display -->
          <div class="gift-card-preview rounded-xl p-8 max-w-sm mx-auto text-center mb-6 bg-gradient-to-br from-paper to-vintage">
            <div class="mb-3">
              <i class="fa-solid fa-cloud text-accent text-3xl"></i>
            </div>
            <h4 id="gift-plan-display" class="font-serif font-semibold text-xl text-ink mb-1">Plano Vitalício</h4>
            <p class="text-xs text-gray-600 font-body mb-4">Notícias do Céu</p>
            <div class="separator-line"></div>
            <p class="text-sm font-body italic text-ink/70 mb-3" id="gift-message-display">
              "Sua mensagem aparecerá aqui..."
            </p>
            <p class="text-xs text-accent font-serif mb-4" id="gift-giver-display">— Seu amigo</p>
            <div class="separator-line"></div>
            <p id="gift-features-display" class="text-[10px] text-gray-500 uppercase tracking-widest">
              Acesso vitalício • arquivo completo • compilado em PDF
            </p>
          </div>

          <div class="bg-accent/10 rounded-xl p-4 border border-accent/20 mb-6 text-center">
            <p class="text-sm text-ink font-body">
              <i class="fa-solid fa-paw text-accent"></i>
              <strong>Parte do valor</strong> deste presente foi destinada a ONGs de proteção animal.
            </p>
          </div>

          <div class="flex flex-col gap-3">
            <button type="button" onclick="goToStep(3)"
              class="w-full bg-accent text-white py-4 rounded-xl font-serif font-bold text-lg hover:bg-ink transition-colors shadow-lg flex items-center justify-center gap-2 cursor-pointer">
              <i class="fa-solid fa-arrow-right"></i> Começar Minha Homenagem
            </button>
          </div>
        </div>

        <!-- STEP 3: Onboarding / Memorial Creation -->
        <div id="step-3" class="step-content">
          <div class="text-center mb-8">
            <div class="w-16 h-16 mx-auto bg-accent/10 rounded-full flex items-center justify-center mb-4">
              <i class="fa-solid fa-seedling text-accent text-2xl"></i>
            </div>
            <h2 class="text-3xl font-serif font-bold text-ink mb-2">Vamos Criar seu Memorial</h2>
            <p class="text-gray-600 font-body">Conte-nos sobre seu companheiro para começarmos a história</p>
          </div>

          <form id="memorial-form" class="space-y-5">
            <div>
              <label class="block text-sm font-bold text-ink mb-1">Nome do seu pet *</label>
              <input type="text" id="pet-name" required
                class="w-full px-4 py-3 rounded-lg border-2 border-ink/20 bg-white focus:border-accent focus:outline-none transition-colors font-body"
                placeholder="Ex: Flokinho">
            </div>

            <div class="grid grid-cols-2 gap-3">
              <div>
                <label class="block text-sm font-bold text-ink mb-1">Raça *</label>
                <input type="text" id="pet-breed" required
                  class="w-full px-4 py-3 rounded-lg border-2 border-ink/20 bg-white focus:border-accent focus:outline-none transition-colors font-body"
                  placeholder="Ex: Shih Tzu">
              </div>
              <div>
                <label class="block text-sm font-bold text-ink mb-1">Apelido carinhoso</label>
                <input type="text" id="pet-nickname"
                  class="w-full px-4 py-3 rounded-lg border-2 border-ink/20 bg-white focus:border-accent focus:outline-none transition-colors font-body"
                  placeholder="Ex: Floquinho de Neve">
              </div>
            </div>

            <div>
              <label class="block text-sm font-bold text-ink mb-1">O que ele(a) mais amava? *</label>
              <input type="text" id="pet-love" required
                class="w-full px-4 py-3 rounded-lg border-2 border-ink/20 bg-white focus:border-accent focus:outline-none transition-colors font-body"
                placeholder="Ex: dormir no pé da cama">
            </div>

            <div>
              <label class="block text-sm font-bold text-ink mb-1">Brinquedo favorito</label>
              <input type="text" id="pet-toy"
                class="w-full px-4 py-3 rounded-lg border-2 border-ink/20 bg-white focus:border-accent focus:outline-none transition-colors font-body"
                placeholder="Ex: bolinha azul">
            </div>

            <div>
              <label class="block text-sm font-bold text-ink mb-1">Comida predileta</label>
              <input type="text" id="pet-food"
                class="w-full px-4 py-3 rounded-lg border-2 border-ink/20 bg-white focus:border-accent focus:outline-none transition-colors font-body"
                placeholder="Ex: bifinho de carne">
            </div>

            <div>
              <label class="block text-sm font-bold text-ink mb-1">Uma travessura inesquecível</label>
              <textarea id="pet-mischief" rows="2"
                class="w-full px-4 py-3 rounded-lg border-2 border-ink/20 bg-white focus:border-accent focus:outline-none transition-colors font-body resize-none"
                placeholder="Ex: roubou um chinelo e escondeu debaixo do sofá..."></textarea>
            </div>

            <div>
              <label class="block text-sm font-bold text-ink mb-1">Foto do pet (em breve)</label>
              <div class="w-full px-4 py-8 rounded-lg border-2 border-dashed border-ink/20 bg-gray-50 text-center text-gray-400">
                <i class="fa-solid fa-cloud-arrow-up text-2xl mb-2"></i>
                <p class="text-sm font-body">Upload de fotos em breve</p>
              </div>
            </div>

            <button type="submit"
              class="w-full bg-accent text-white py-4 rounded-xl font-serif font-bold text-lg hover:bg-ink transition-colors shadow-lg flex items-center justify-center gap-2 cursor-pointer">
              <i class="fa-solid fa-paper-plane"></i> Criar Memorial
            </button>
          </form>
        </div>

        <!-- STEP 4: Success -->
        <div id="step-4" class="step-content">
          <div class="text-center">
            <div class="w-20 h-20 mx-auto bg-green-100 rounded-full flex items-center justify-center mb-4">
              <i class="fa-solid fa-check text-green-600 text-4xl"></i>
            </div>
            <h2 class="text-3xl font-serif font-bold text-ink mb-3">Memorial Criado com Amor!</h2>
            <p class="text-gray-600 font-body mb-6 max-w-md mx-auto">
              Seu espaço de homenagem está pronto. A cada dia, uma nova edição do jornal do céu será publicada para você se emocionar.
            </p>

            <div class="bg-paper/50 rounded-xl p-5 border border-ink/10 mb-6 text-left">
              <h5 class="font-serif font-semibold text-lg mb-3 flex items-center gap-2 text-ink">
                <i class="fa-solid fa-star text-accent"></i> O que você ganhou:
              </h5>
              <ul id="success-features-list" class="space-y-2 text-sm font-body text-gray-700">
                <li class="flex items-start gap-2">
                  <i class="fa-solid fa-check text-green-600 mt-0.5"></i>
                  <span><strong>Plano Vitalício</strong>: acesso para sempre</span>
                </li>
                <li class="flex items-start gap-2">
                  <i class="fa-solid fa-check text-green-600 mt-0.5"></i>
                  <span><strong>Jornal diário</strong>: nova edição todo dia</span>
                </li>
                <li class="flex items-start gap-2">
                  <i class="fa-solid fa-check text-green-600 mt-0.5"></i>
                  <span><strong>Arquivo do Jornal</strong>: releia edições passadas</span>
                </li>
                <li class="flex items-start gap-2">
                  <i class="fa-solid fa-check text-green-600 mt-0.5"></i>
                  <span><strong>Compartilhamento avançado</strong>: links para edições específicas</span>
                </li>
                <li class="flex items-start gap-2">
                  <i class="fa-solid fa-check text-green-600 mt-0.5"></i>
                  <span><strong>Compilado em PDF</strong>: exporte todas as edições</span>
                </li>
              </ul>
            </div>

            <div class="flex flex-col sm:flex-row gap-3 justify-center">
              <a href="/#demonstracao"
                class="bg-accent text-white px-8 py-4 rounded-xl font-serif font-bold hover:bg-ink transition-colors shadow-lg flex items-center justify-center gap-2">
                <i class="fa-regular fa-eye"></i> Ver Exemplo
              </a>
              <a href="/"
                class="bg-white text-ink border-2 border-ink px-8 py-4 rounded-xl font-serif font-bold hover:bg-gray-50 transition-colors flex items-center justify-center gap-2">
                <i class="fa-solid fa-home"></i> Voltar ao Início
              </a>
            </div>
          </div>
        </div>

        <!-- Loading Overlay -->
        <div id="loading-overlay" class="hidden absolute inset-0 bg-paper/80 backdrop-blur-sm rounded-xl flex flex-col items-center justify-center z-20">
          <div class="spinner mb-4"></div>
          <p class="font-serif font-bold text-ink" id="loading-text">Validando código...</p>
        </div>

      </div>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const CONFIG = {
    API_BASE_URL: null, // Runs in mock mode in this flow
  };

  let redeemData = {
    code: '',
    giverName: '',
    recipientName: '',
    message: '',
    plan: 'lifetime'
  };

  function goToStep(step) {
    document.querySelectorAll('.step-content').forEach(el => el.classList.remove('active'));
    
    const stepEl = document.getElementById(`step-${step}`);
    if (stepEl) stepEl.classList.add('active');

    const container = document.querySelector('.newspaper-container');
    if (container) {
      container.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }

  function formatCodeInput(input) {
    let value = input.value.replace(/[^A-Z0-9]/gi, '').toUpperCase();
    let formatted = '';
    for (let i = 0; i < value.length && i < 12; i++) {
      if (i > 0 && i % 4 === 0) formatted += '-';
      formatted += value[i];
    }
    input.value = formatted;
  }

  // Check for code in URL params
  const urlParams = new URLSearchParams(window.location.search);
  const urlCode = urlParams.get('code');
  if (urlCode) {
    const input = document.getElementById('gift-code-input') as HTMLInputElement | null;
    if (input) {
      input.value = urlCode;
      formatCodeInput(input);
    }
  }

  // Step 1: Code validation
  const redeemForm = document.getElementById('redeem-form');
  if (redeemForm) {
    redeemForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const codeInput = document.getElementById('gift-code-input') as HTMLInputElement | null;
      const code = codeInput?.value.trim().toUpperCase() || '';
      const name = (document.getElementById('redeemer-name') as HTMLInputElement | null)?.value.trim() || '';
      const email = (document.getElementById('redeemer-email') as HTMLInputElement | null)?.value.trim() || '';
      const errorEl = document.getElementById('code-error');

      if (!code || code.replace(/-/g, '').length !== 12) {
        if (errorEl) {
          errorEl.textContent = 'O código deve ter 12 caracteres. Verifique e tente novamente.';
          errorEl.classList.remove('hidden');
        }
        return;
      }

      if (!name || !email) {
        if (errorEl) {
          errorEl.textContent = 'Preencha seu nome e e-mail.';
          errorEl.classList.remove('hidden');
        }
        return;
      }

      const overlay = document.getElementById('loading-overlay');
      const loadText = document.getElementById('loading-text');
      if (loadText) loadText.textContent = 'Validando código...';
      if (overlay) overlay.classList.remove('hidden');

      try {
        await delay(1500);

        // Search in localStorage saved gift cards
        let savedCards = [];
        try {
          savedCards = JSON.parse(localStorage.getItem('ndc_gift_cards') || '[]');
        } catch(e) {}
        
        const matchedCard = savedCards.find(c => c.code === code);
        
        if (matchedCard) {
          redeemData = {
            code,
            giverName: matchedCard.giverName,
            recipientName: matchedCard.recipientName,
            message: matchedCard.message ? `"${matchedCard.message}"` : '"Mensagem de carinho..."',
            plan: matchedCard.plan || 'lifetime'
          };
        } else {
          // Fallback to default mock gift card data
          const isAnnual = code.startsWith('A') || code.includes('ANUAL');
          redeemData = {
            code,
            giverName: 'Seu amigo',
            recipientName: name,
            message: '"Querido amigo, sei o quanto o seu companheiro era especial. Espero que este espaço traga um pouco de acalento para o seu coração. Com carinho."',
            plan: isAnnual ? 'annual' : 'lifetime'
          };
        }

        if (overlay) overlay.classList.add('hidden');

        // Show gift message
        const msgDisplay = document.getElementById('gift-message-display');
        const givDisplay = document.getElementById('gift-giver-display');
        if (msgDisplay) msgDisplay.textContent = redeemData.message;
        if (givDisplay) givDisplay.textContent = `— ${redeemData.giverName}`;

        // Update plan preview in Step 2
        const planDisplay = document.getElementById('gift-plan-display');
        const featuresDisplay = document.getElementById('gift-features-display');
        if (redeemData.plan === 'annual') {
          if (planDisplay) planDisplay.textContent = 'Plano Anual';
          if (featuresDisplay) featuresDisplay.textContent = 'Acesso por 1 ano • Jornal diário • compartilhamento';
        } else {
          if (planDisplay) planDisplay.textContent = 'Plano Vitalício';
          if (featuresDisplay) featuresDisplay.textContent = 'Acesso vitalício • arquivo completo • compilado em PDF';
        }

        goToStep(2);
      } catch (err) {
        if (overlay) overlay.classList.add('hidden');
        if (errorEl) {
          errorEl.textContent = 'Código inválido ou já utilizado. Verifique e tente novamente.';
          errorEl.classList.remove('hidden');
        }
      }
    });
  }

  // Step 3: Memorial creation
  const memorialForm = document.getElementById('memorial-form');
  if (memorialForm) {
    memorialForm.addEventListener('submit', async (e) => {
      e.preventDefault();

      const memorialData = {
        petName: (document.getElementById('pet-name') as HTMLInputElement | null)?.value.trim() || '',
        petBreed: (document.getElementById('pet-breed') as HTMLInputElement | null)?.value.trim() || '',
        petNickname: (document.getElementById('pet-nickname') as HTMLInputElement | null)?.value.trim() || '',
        petLove: (document.getElementById('pet-love') as HTMLInputElement | null)?.value.trim() || '',
        petToy: (document.getElementById('pet-toy') as HTMLInputElement | null)?.value.trim() || '',
        petFood: (document.getElementById('pet-food') as HTMLInputElement | null)?.value.trim() || '',
        petMischief: (document.getElementById('pet-mischief') as HTMLTextAreaElement | null)?.value.trim() || '',
      };

      const overlay = document.getElementById('loading-overlay');
      const loadText = document.getElementById('loading-text');
      if (loadText) loadText.textContent = 'Criando seu memorial...';
      if (overlay) overlay.classList.remove('hidden');

      try {
        await delay(2000);
        console.log('[MOCK] Memorial created:', memorialData);
        console.log('[MOCK] Gift card redeemed:', redeemData.code);

        if (overlay) overlay.classList.add('hidden');
        
        // Update features list in Step 4
        const successFeaturesList = document.getElementById('success-features-list');
        if (successFeaturesList) {
          if (redeemData.plan === 'annual') {
            successFeaturesList.innerHTML = `
              <li class="flex items-start gap-2">
                <i class="fa-solid fa-check text-green-600 mt-0.5"></i>
                <span><strong>Plano Anual</strong>: acesso por 1 ano</span>
              </li>
              <li class="flex items-start gap-2">
                <i class="fa-solid fa-check text-green-600 mt-0.5"></i>
                <span><strong>Jornal diário</strong>: nova edição todo dia</span>
              </li>
              <li class="flex items-start gap-2">
                <i class="fa-solid fa-check text-green-600 mt-0.5"></i>
                <span><strong>Compartilhamento simples</strong>: link mostra a edição do momento</span>
              </li>
            `;
          } else {
            successFeaturesList.innerHTML = `
              <li class="flex items-start gap-2">
                <i class="fa-solid fa-check text-green-600 mt-0.5"></i>
                <span><strong>Plano Vitalício</strong>: acesso para sempre</span>
              </li>
              <li class="flex items-start gap-2">
                <i class="fa-solid fa-check text-green-600 mt-0.5"></i>
                <span><strong>Jornal diário</strong>: nova edição todo dia</span>
              </li>
              <li class="flex items-start gap-2">
                <i class="fa-solid fa-check text-green-600 mt-0.5"></i>
                <span><strong>Arquivo do Jornal</strong>: releia edições passadas</span>
              </li>
              <li class="flex items-start gap-2">
                <i class="fa-solid fa-check text-green-600 mt-0.5"></i>
                <span><strong>Compartilhamento avançado</strong>: links para edições específicas</span>
              </li>
              <li class="flex items-start gap-2">
                <i class="fa-solid fa-check text-green-600 mt-0.5"></i>
                <span><strong>Compilado em PDF</strong>: exporte todas as edições</span>
              </li>
            `;
          }
        }
        goToStep(4);
      } catch (err) {
        if (overlay) overlay.classList.add('hidden');
        alert('Erro ao criar memorial. Tente novamente.');
      }
    });
  }

  function delay(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
  }

  // Expose to window for inline onclick handlers
  window.goToStep = goToStep;
  window.formatCodeInput = formatCodeInput;
</script>
