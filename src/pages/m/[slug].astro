---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { PetService } from '../../services/pet-service.js';

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

// Fetch pet with day counter directly from DB service
const pet = await PetService.getPetWithDay(slug);

if (!pet) {
  return Astro.redirect('/');
}
---

<Layout title={`${pet.name} — Memorial | Notícias do Céu`}>
  <Navbar showCreateMemorial={false} />

  <main class="flex-grow pt-32 pb-20 bg-gradient-to-b from-paper/30 to-white text-ink">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Memorial Header -->
      <div class="newspaper-container border-double-thick p-8 bg-white mb-8">
        <div class="text-center border-b-2 border-ink pb-4 mb-6">
          <p class="text-[10px] font-bold uppercase tracking-widest mb-1 text-accent">Memorial Celestial</p>
          <h1 class="font-serif text-4xl font-black uppercase tracking-tighter text-ink">{pet.name}</h1>
          <p class="text-sm text-gray-600 mt-2">{pet.breed} · {pet.gender}</p>
        </div>

        <!-- Day Counter -->
        <div class="text-center mb-8">
          <div class="inline-flex items-center gap-3 bg-accent/10 border border-accent/20 rounded-2xl px-8 py-4">
            <i class="fa-solid fa-calendar-day text-accent text-2xl"></i>
            <div>
              <p class="text-[10px] font-bold uppercase tracking-widest text-accent">Contagem Celestial</p>
              <p class="font-serif text-3xl font-black text-ink">Dia {pet.dayNumber}</p>
            </div>
          </div>
        </div>

        <!-- Photo Gallery -->
        {pet.photos && pet.photos.length > 0 && (
          <div class="mb-8">
            <h3 class="font-serif font-bold text-lg uppercase mb-4 pb-2 border-b border-gray-200 text-ink">
              <i class="fa-solid fa-images mr-2"></i> Galeria de Memórias
            </h3>
            <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-4">
              {pet.photos.map((photo, idx) => (
                <div key={idx} class="aspect-square rounded-xl overflow-hidden border border-gray-200 bg-gray-50 shadow-sm">
                  <img src={photo} alt={`Foto ${idx + 1} de ${pet.name}`} class="w-full h-full object-cover" />
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Nicknames -->
        {pet.nicknames && pet.nicknames.length > 0 && (
          <div class="mb-6">
            <h3 class="font-serif font-bold text-sm uppercase tracking-wider mb-2 text-ink">
              <i class="fa-solid fa-heart mr-2 text-accent"></i> Apelidos Carinhosos
            </h3>
            <div class="flex flex-wrap gap-2">
              {pet.nicknames.map((nick, idx) => (
                <span key={idx} class="inline-flex items-center bg-accent/10 text-accent text-xs px-3 py-1.5 rounded-lg border border-accent/15 font-medium">
                  {nick}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Personalities -->
        {pet.personalities && pet.personalities.length > 0 && (
          <div class="mb-6">
            <h3 class="font-serif font-bold text-sm uppercase tracking-wider mb-2 text-ink">
              <i class="fa-solid fa-star mr-2 text-accent"></i> Personalidade
            </h3>
            <div class="flex flex-wrap gap-2">
              {pet.personalities.map((trait, idx) => (
                <span key={idx} class="inline-flex items-center bg-gray-100 text-gray-800 text-xs px-3 py-1.5 rounded-lg border border-gray-200 font-medium">
                  {trait}
                </span>
              ))}
            </div>
          </div>
        )}

        <!-- Favorite Place & Object -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
          {pet.favoritePlace && (
            <div class="p-4 bg-paper/20 rounded-xl border border-gray-200">
              <p class="text-[10px] font-bold uppercase tracking-widest text-accent mb-1">Lugar Favorito</p>
              <p class="font-serif text-sm text-ink">{pet.favoritePlace}</p>
            </div>
          )}
          {pet.favoriteObject && (
            <div class="p-4 bg-paper/20 rounded-xl border border-gray-200">
              <p class="text-[10px] font-bold uppercase tracking-widest text-accent mb-1">Objeto Favorito</p>
              <p class="font-serif text-sm text-ink">{pet.favoriteObject}</p>
            </div>
          )}
        </div>

        <!-- Actions -->
        <div class="flex flex-col sm:flex-row gap-4 pt-6 border-t border-gray-100">
          <a
            href={`/letter?petName=${encodeURIComponent(pet.name)}`}
            class="bg-accent text-white px-6 py-3 rounded-full font-serif font-bold hover:bg-ink transition-colors text-center inline-flex items-center justify-center gap-2"
          >
            <i class="fa-solid fa-envelope-open-text"></i> Escrever uma Carta
          </a>
          <a
            href="/"
            class="bg-white text-ink border-2 border-ink px-6 py-3 rounded-full font-serif font-bold hover:bg-gray-50 transition-colors text-center inline-flex items-center justify-center gap-2"
          >
            <i class="fa-solid fa-house"></i> Voltar ao Início
          </a>
        </div>
      </div>

      <!-- Footer Info -->
      <div class="text-center text-xs text-gray-500 mt-8">
        <p>Memorial criado em {new Date(pet.createdAt).toLocaleDateString('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' })}</p>
        <p class="mt-1">Notícias do Céu — Lembranças que transcendem</p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
