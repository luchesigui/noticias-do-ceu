---
import Layout from '../../layouts/Layout.astro';
import { PetService } from '../../services/pet-service.js';

export const prerender = false;

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/');
}

// Fetch pet with day counter from Supabase
const pet = await PetService.getPetWithDay(slug);

if (!pet) {
  return Astro.redirect('/');
}

// Calculate day number (at least 1)
const dayNumber = Math.max(1, pet.day_number || 1);

// Seed-based PRNG (seeded hash for procedural grammar)
function seededRandom(seed) {
  let hash = 0;
  const str = seed + String(dayNumber);
  for (let i = 0; i < str.length; i++) {
    const char = str.charCodeAt(i);
    hash = ((hash << 5) - hash) + char;
    hash |= 0;
  }
  const x = Math.sin(hash) * 10000;
  return x - Math.floor(x);
}

// Procedural content generation
function generateHeadline() {
  const templates = [
    `${pet.name} completa ${dayNumber} dia(s) de memórias no céu`,
    `O ${dayNumber}º dia de ${pet.name} além das nuvens`,
    `Homenagem: ${pet.name} brilha no dia ${dayNumber}`,
    `Há ${dayNumber} dia(s), ${pet.name} escreve sua história no paraíso`,
  ];
  const idx = Math.floor(seededRandom(pet.seed + 'headline') * templates.length);
  return templates[idx];
}

function generateDayDescriptor() {
  const descriptors = [
    'sereno', 'luminoso', 'pacífico', 'radiante',
    'gentil', 'acolhedor', 'dourado', 'misterioso',
    'calmo', 'feliz', 'brilhante', 'tranquilo',
  ];
  const idx = Math.floor(seededRandom(pet.seed + 'descriptor') * descriptors.length);
  return descriptors[idx];
}

function generateBodyParagraph() {
  const nick = pet.nicknames?.length > 0
    ? pet.nicknames[Math.floor(seededRandom(pet.seed + 'nick') * pet.nicknames.length)]
    : pet.name;

  const traits = pet.personalities?.length > 0
    ? pet.personalities[Math.floor(seededRandom(pet.seed + 'trait') * pet.personalities.length)]
    : 'carinhoso';

  const place = pet.favoritePlace || 'o paraíso dos animais';
  const obj = pet.favoriteObject || 'seus brinquedos favoritos';

  const openings = [
    `Neste ${generateDayDescriptor()} dia ${dayNumber}, ${nick} corre livre pelos campos do céu,`,
    `Hoje marca o dia ${dayNumber} de uma jornada ${generateDayDescriptor()}, e ${nick} está no centro de tudo,`,
    `No ${dayNumber}º dia no paraíso, ${nick} nos lembra que o amor não tem fim,`,
  ];

  const middles = [
    `com aquele espírito ${traits} que marcou a vida de todos que tiveram a sorte de conviver.`,
    `trazendo para ${place} a energia ${traits} que sempre definiu sua essência.`,
    `onde cada momento em ${place} é preenchido com alegria e travessuras ${traits}.`,
  ];

  const endings = [
    `As lembranças de ${obj} fazem sorrir a todos os anjos ao redor.`,
    `Dizem que ${obj} se transformou em relíquia celestial, guardada com carinho.`,
    `Até os querubins param para admirar a alegria que ${nick} espalha.`,
  ];

  const oIdx = Math.floor(seededRandom(pet.seed + 'open') * openings.length);
  const mIdx = Math.floor(seededRandom(pet.seed + 'mid') * middles.length);
  const eIdx = Math.floor(seededRandom(pet.seed + 'end') * endings.length);

  return `${openings[oIdx]} ${middles[mIdx]} ${endings[eIdx]}`;
}

function generateClosingQuote() {
  const quotes = [
    `"${pet.name} não se foi — apenas chegou antes de nós, para preparar o lugar."`,
    `"O amor de um pet é eterno. Cada dia no céu é uma prova disso."`,
    `"Aqueles que amamos nunca morrem, apenas mudam de lugar — para o céu."`,
    `"${pet.name} nos ensinou que o amor mais puro anda em quatro patas."`,
  ];
  const idx = Math.floor(seededRandom(pet.seed + 'quote') * quotes.length);
  return quotes[idx];
}

const headline = generateHeadline();
const body = generateBodyParagraph();
const quote = generateClosingQuote();
const formattedDate = new Date().toLocaleDateString('pt-BR', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

---

<Layout title={`${pet.name} — Memorial | Notícias do Céu`}>
  <main class="min-h-screen bg-gradient-to-b from-paper/40 to-white pt-24 pb-16">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Newspaper Container -->
      <article class="newspaper-container border-double-thick bg-white p-8 md:p-12">

        <!-- Newspaper Masthead -->
        <header class="text-center border-b-2 border-ink pb-6 mb-8">
          <div class="flex justify-between items-center text-[10px] uppercase tracking-widest text-gray-500 mb-2">
            <span>Edição Nº {dayNumber}</span>
            <span>{formattedDate}</span>
          </div>
          <h1 class="font-serif text-4xl md:text-5xl font-black uppercase tracking-tighter text-ink">
            Notícias do Céu
          </h1>
          <div class="w-24 h-0.5 bg-accent mx-auto mt-4"></div>
        </header>

        <!-- Headline -->
        <div class="text-center mb-8">
          <h2 class="font-serif text-2xl md:text-3xl font-bold text-ink leading-tight">
            {headline}
          </h2>
          <p class="text-sm text-gray-500 mt-3 italic">
            Em homenagem a {pet.name} • {pet.breed} • {pet.gender}
          </p>
        </div>

        <!-- Photo Gallery (if available) -->
        {pet.photos && pet.photos.length > 0 && (
          <div class="mb-8">
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              {pet.photos.slice(0, 5).map((photo, idx) => (
                <div class="aspect-square rounded-xl overflow-hidden border border-gray-200 bg-gray-50 shadow-sm">
                  <img
                    src={photo}
                    alt={`Foto ${idx + 1} de ${pet.name}`}
                    class="w-full h-full object-cover"
                    loading="lazy"
                  />
                </div>
              ))}
            </div>
          </div>
        )}

        <!-- Divider -->
        <div class="separator-line mb-8"></div>

        <!-- Body Content -->
        <div class="prose prose-lg max-w-none font-body text-ink">
          <p class="first-letter:text-5xl first-letter:font-serif first-letter:font-black first-letter:float-left first-letter:mr-3 first-letter:leading-none first-letter:text-accent">
            {body}
          </p>
        </div>

        <!-- Day Badge -->
        <div class="text-center my-8">
          <div class="inline-flex items-center gap-2 bg-accent/10 text-accent px-4 py-2 rounded-full text-sm font-bold">
            <i class="fa-solid fa-calendar-day"></i>
            Dia {dayNumber} no paraíso
          </div>
        </div>

        <!-- Nicknames & Personalities -->
        {(pet.nicknames?.length > 0 || pet.personalities?.length > 0) && (
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4 my-8">
            {pet.nicknames?.length > 0 && (
              <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                <span class="block text-[10px] font-bold uppercase text-gray-400 tracking-wider mb-2">
                  Apelidos Carinhosos
                </span>
                <div class="flex flex-wrap gap-1.5">
                  {pet.nicknames.map(n => (
                    <span class="bg-white text-gray-700 text-xs px-2.5 py-1 rounded-md font-medium border border-gray-200">
                      {n}
                    </span>
                  ))}
                </div>
              </div>
            )}

            {pet.personalities?.length > 0 && (
              <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
                <span class="block text-[10px] font-bold uppercase text-gray-400 tracking-wider mb-2">
                  Personalidade
                </span>
                <div class="flex flex-wrap gap-1.5">
                  {pet.personalities.map(p => (
                    <span class="bg-accent/10 text-accent text-xs px-2.5 py-1 rounded-md font-medium border border-accent/15">
                      {p}
                    </span>
                  ))}
                </div>
              </div>
            )}
          </div>
        )}

        <!-- Divider -->
        <div class="separator-line my-8"></div>

        <!-- Closing Quote -->
        <blockquote class="text-center py-6">
          <p class="font-serif text-xl md:text-2xl italic text-ink/80 leading-relaxed">
            {quote}
          </p>
          <footer class="mt-4 text-sm text-gray-500">
            — Com amor, diretamente do céu
          </footer>
        </blockquote>

        <!-- Share / Back -->
        <div class="text-center mt-10 flex flex-wrap justify-center gap-3">
          <button
            onclick="shareMemorial()"
            class="bg-ink text-paper px-6 py-2.5 rounded-full font-serif font-bold text-sm hover:bg-accent transition-colors inline-flex items-center gap-1.5 cursor-pointer"
          >
            <i class="fa-solid fa-share-nodes"></i> Compartilhar Memorial
          </button>
          <button
            onclick="window.print()"
            class="bg-white text-ink border-2 border-ink px-6 py-2.5 rounded-full font-serif font-bold text-sm hover:bg-gray-50 transition-colors inline-flex items-center gap-1.5 cursor-pointer"
          >
            <i class="fa-solid fa-print"></i> Imprimir
          </button>
        </div>

      </article>

      <!-- Footer Note -->
      <footer class="text-center mt-8 text-xs text-gray-400">
        <p>Este memorial é gerado proceduralmente com base nas informações carinhosas de familiares e amigos.</p>
        <p class="mt-1">Notícias do Céu — Onde memórias vivem para sempre.</p>
      </footer>

    </div>
  </main>
</Layout>

<script>
  function shareMemorial() {
    const url = window.location.href;
    const title = `Memorial de ${document.querySelector('h2')?.textContent || 'pet'}`;

    if (navigator.share) {
      navigator.share({ title, url });
    } else {
      navigator.clipboard.writeText(url).then(() => {
        alert('Link do memorial copiado!');
      }).catch(() => {
        prompt('Copie o link do memorial:', url);
      });
    }
  }

  window.shareMemorial = shareMemorial;
</script>
